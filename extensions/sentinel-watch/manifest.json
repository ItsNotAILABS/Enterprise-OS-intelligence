{
  "manifest_version": 3,
  "name": "Sentinel Watch",
  "version": "1.0.0",
  "description": "Security Intelligence Monitor — Guards + GPT + Claude",
  "permissions": [
    "activeTab",
    "webRequest",
    "webNavigation",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "minimum_chrome_version": "110"
}
