{
  "manifest_version": 3,
  "name": "Voice Forge",
  "version": "1.0.0",
  "description": "Audio Intelligence Studio — Whisper + ElevenLabs + Suno",
  "permissions": ["activeTab", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "minimum_chrome_version": "110"
}
