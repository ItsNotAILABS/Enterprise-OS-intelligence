{
  "manifest_version": 3,
  "name": "Cipher Shield",
  "version": "1.0.0",
  "description": "Encrypted Intelligence Guard — Security + GPT + Claude",
  "permissions": ["activeTab", "storage", "webRequest"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "minimum_chrome_version": "110"
}
