{
  "manifest_version": 3,
  "name": "Polyglot Oracle",
  "version": "1.0.0",
  "description": "Multilingual Translation Intelligence — Qwen + Gemini + Llama",
  "permissions": ["activeTab", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "minimum_chrome_version": "110"
}
