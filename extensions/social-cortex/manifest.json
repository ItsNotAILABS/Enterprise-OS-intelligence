{
  "manifest_version": 3,
  "name": "Social Cortex",
  "version": "1.0.0",
  "description": "Social Intelligence Analyzer — Grok + Inflection + GPT",
  "permissions": ["activeTab", "storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "minimum_chrome_version": "110"
}
