{
  "manifest_version": 3,
  "name": "Memory Palace",
  "version": "1.0.0",
  "description": "Spatial Memory Intelligence — Embeddings + Command R + Rerankers",
  "permissions": ["activeTab", "storage", "bookmarks", "history"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "minimum_chrome_version": "110"
}
