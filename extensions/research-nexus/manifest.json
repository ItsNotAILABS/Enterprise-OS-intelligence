{
  "manifest_version": 3,
  "name": "Research Nexus",
  "version": "1.0.0",
  "description": "Search-Augmented Research Intelligence — Perplexity + Claude + Embeddings",
  "permissions": ["activeTab", "storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "minimum_chrome_version": "110"
}
