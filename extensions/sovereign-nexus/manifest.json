{
  "manifest_version": 3,
  "name": "Sovereign Nexus",
  "version": "1.0.0",
  "description": "Unified Intelligence Hub — All 40 Foundation Models",
  "permissions": ["activeTab", "storage", "tabs", "identity", "management"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "minimum_chrome_version": "110"
}
