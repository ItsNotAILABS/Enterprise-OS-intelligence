{
  "manifest_version": 3,
  "name": "Data Alchemist",
  "version": "1.0.0",
  "description": "Document Absorption Intelligence — GPT + Claude + Embeddings + Rerankers",
  "permissions": ["activeTab", "storage", "downloads"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "minimum_chrome_version": "110"
}
