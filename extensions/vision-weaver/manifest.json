{
  "manifest_version": 3,
  "name": "Vision Weaver",
  "version": "1.0.0",
  "description": "Visual Intelligence Compositor — DALL-E + Stable Diffusion + Midjourney + SAM",
  "permissions": [
    "activeTab",
    "storage",
    "downloads"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "minimum_chrome_version": "110"
}
