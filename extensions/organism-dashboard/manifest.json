{
  "manifest_version": 3,
  "name": "Organism Dashboard",
  "version": "1.0.0",
  "description": "Organism Runtime Intelligence — Heartbeat + OrganismState + EdgeSensor",
  "permissions": ["activeTab", "storage", "alarms"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "minimum_chrome_version": "110"
}
